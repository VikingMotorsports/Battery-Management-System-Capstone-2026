mainmenu "BMS Monitor"

menu "Application monitor options"

config APP_VOLTAGE_MONITORING
    bool "Enable voltage monitoring"
    default y
    help
      Enable cell voltage monitoring.

config APP_TEMPERATURE_MONITORING
    bool "Enable temperature monitoring"
    default y
    help
      Enable temperature monitoring.

config APP_CURRENT_MONITORING
    bool "Enable current monitoring"
    default y
    help
      Enable current monitoring.

config APP_FAULT_MONITORING
    bool "Enable fault monitoring"
    default y
    depends on APP_VOLTAGE_MONITORING || APP_TEMPERATURE_MONITORING || APP_CURRENT_MONITORING
    help
      Enable fault monitoring.

config APP_CELL_BALANCING
    bool "Enable cell balancing"
    default y
    depends on APP_VOLTAGE_MONITORING
    help
      Enable cell balancing.

config APP_CAN_TELEMETRY
    bool "Enable CAN telemetry transmission"
    default y
    depends on APP_VOLTAGE_MONITORING || APP_TEMPERATURE_MONITORING || APP_CURRENT_MONITORING
    help
      Enable BMS telemetry transmission over CAN.

endmenu

menu "Application debug options"

config APP_DEBUG_PRINTS
    bool "Enable application debug printing"
    default y
    help
      Master switch for application debug printing helpers.

config APP_DEBUG_VOLTAGES
    bool "Enable voltage debug printing"
    default y
    depends on APP_DEBUG_PRINTS && APP_VOLTAGE_MONITORING
    help
      Print cell voltage debug output.

config APP_DEBUG_TEMPERATURES
    bool "Enable temperature debug printing"
    default y
    depends on APP_DEBUG_PRINTS && APP_TEMPERATURE_MONITORING
    help
      Print temperature debug output.

config APP_DEBUG_CURRENT
    bool "Enable current debug printing"
    default y
    depends on APP_DEBUG_PRINTS && APP_CURRENT_MONITORING
    help
      Print current debug output.

config APP_DEBUG_FAULTS
    bool "Enable fault debug printing"
    default y
    depends on APP_DEBUG_PRINTS && APP_FAULT_MONITORING
    help
      Print fault debug output.

config APP_DEBUG_BALANCING
    bool "Enable cell balancing debug printing"
    default y
    depends on APP_DEBUG_PRINTS && APP_CELL_BALANCING
    help
      Print cell balancing debug output.

config APP_DEBUG_CAN_TELEMETRY
    bool "Enable CAN telemetry debug printing"
    default y
    depends on APP_DEBUG_PRINTS && APP_CAN_TELEMETRY
    help
      Print CAN telemetry debug output.

endmenu

source "Kconfig.zephyr"
